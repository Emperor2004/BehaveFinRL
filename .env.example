# Alpha Vantage API Key (required to fetch asset prices and technical indicator data)
# Obtain a key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Federal Reserve Economic Data (FRED) API Key (required to fetch macroeconomic indicators like T10Y2Y)
# Obtain a key at: https://fred.stlouisfed.org/api/api_key.html
FRED_API_KEY=your_fred_api_key_here
